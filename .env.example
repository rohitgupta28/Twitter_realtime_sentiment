# ============================================================
# COPY THIS FILE TO .env AND FILL IN YOUR VALUES
# cp .env.example .env
# ============================================================

# ── Twitter / X API v2 ──────────────────────────────────────
# Get these from https://developer.twitter.com/en/portal/dashboard
# You need a FREE developer account → create a Project → App
# Then go to "Keys and Tokens" and generate a Bearer Token
TWITTER_BEARER_TOKEN=your_bearer_token_here

# Keywords/hashtags to track (comma-separated, no spaces)
# Example: python,machinelearning,AI,datascience
TWITTER_TRACK_KEYWORDS=python,machinelearning,AI,datascience,openai

# ── Kafka ───────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_RAW=tweets-raw           # raw tweets land here
KAFKA_TOPIC_PROCESSED=tweets-processed  # enriched+analyzed tweets here
KAFKA_CONSUMER_GROUP=sentiment-workers

# ── MongoDB ─────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/
DB_NAME=twitter_db
COL_NAME=tweets

# ── Redis ───────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ── NLP Model ───────────────────────────────────────────────
# cardiffnlp/twitter-roberta-base-sentiment-latest is best for tweets
# Use distilbert-base-uncased-finetuned-sst-2-english for a lighter model
HF_MODEL=cardiffnlp/twitter-roberta-base-sentiment-latest
MODEL_VERSION=2.0

# ── FastAPI ─────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Alerts (optional) ───────────────────────────────────────
# Slack webhook URL for negative-spike alerts
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

# Email alerts (uses Gmail SMTP)
ALERT_EMAIL_FROM=youremail@gmail.com
ALERT_EMAIL_PASSWORD=your_app_password   # use Gmail App Password, not your main password
ALERT_EMAIL_TO=notify@yourcompany.com

# Negative sentiment threshold to trigger alert (0.0 to 1.0)
ALERT_NEGATIVE_THRESHOLD=0.65
